# ==========================================
#  CONFIGURACIÓN DEL SERVIDOR
# ==========================================
PORT=3000
NODE_ENV=development

# Origen permitido para CORS (frontend). Separar con coma si son varios.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ==========================================
#  JWT - SECRETS SEPARADOS PARA ADMIN Y CLIENTE
# ==========================================
# ⚠️ Genera secrets fuertes en producción:
#    node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ADMIN_SECRET=cambia_esto_admin_super_secreto
JWT_CLIENTE_SECRET=cambia_esto_cliente_super_secreto
JWT_EXPIRES_IN=8h

# ==========================================
#  AZURACAST
# ==========================================
# ⚠️ NUNCA exponer esta key en el frontend. Solo el backend habla con AzuraCast.
AZURACAST_BASE_URL=https://server1.streaminghd.co
AZURACAST_API_KEY=tu_api_key_de_azuracast_aqui

# URL pública del panel (se usa en la API de provisioning para el login del cliente)
PANEL_URL=https://server2.streaminghd.co

# ==========================================
#  POSTGRESQL
# ==========================================
# Para instalación clásica (PM2 + Postgres nativo):
DATABASE_URL=postgresql://usuario:password@localhost:5432/panel_radio

# Solo para docker-compose: la contraseña de la BD del contenedor.
# (docker-compose arma la DATABASE_URL solo, apuntando al servicio "db")
DB_PASSWORD=cambia_esta_password_de_la_bd

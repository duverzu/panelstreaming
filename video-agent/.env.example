# Puerto del agente (3000 está libre en el VPS de video)
PORT=3000

# Token compartido con el panel. Genera uno con:  openssl rand -hex 24
AGENT_TOKEN=

# Dónde viven las cuentas y la configuración de nginx
HOME_BASE=/home
NGINX_CONF_DIR=/etc/nginx/conf.d

# Carpetas de /home que NO son clientes
IGNORAR=vdopanel,ubuntu,lost+found

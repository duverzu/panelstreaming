# Cuenta {{USER}} — salida de video
# Generado por el panel. No editar a mano: se reescribe.
server {
    listen {{PUERTO_HTTP}} ssl;
    http2 on;
    server_name {{DOMINIO}};

    ssl_certificate     {{CERT_FULLCHAIN}};
    ssl_certificate_key {{CERT_KEY}};

    access_log {{HOME}}/{{USER}}/logs/access.log video;

    # Cabeceras comunes a todo lo que se sirve de este canal
    add_header 'Access-Control-Allow-Origin' '*' always;
    add_header 'Access-Control-Expose-Headers' 'Content-Length' always;

    # --- Las tres salidas de HLS ---
    location /live {
        alias {{HOME}}/{{USER}}/live-streaming/hls;
        add_header 'Cache-Control' 'no-cache' always;
        add_header 'Access-Control-Allow-Origin' '*' always;
    }

    location /stream {
        alias {{HOME}}/{{USER}}/stream/hls;
        add_header 'Cache-Control' 'no-cache' always;
        add_header 'Access-Control-Allow-Origin' '*' always;
    }

    location /hybrid {
        alias {{HOME}}/{{USER}}/stream-hybrid/hls;
        add_header 'Cache-Control' 'no-cache' always;
        add_header 'Access-Control-Allow-Origin' '*' always;
    }

    # --- Videos guardados ---
    location /embed {
        alias {{HOME}}/{{USER}}/uploads;
        add_header 'Access-Control-Allow-Origin' '*' always;
    }
}
# Los add_header 'always' de cada location ya ponen CORS en todas las
# respuestas. No hace falta un bloque OPTIONS aparte: pedir segmentos HLS
# con Range es una "simple request" y no dispara preflight.
